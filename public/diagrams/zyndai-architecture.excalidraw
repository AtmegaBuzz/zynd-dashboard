    {
      "id": "flow-steps",
      "type": "text",
      "x": 60,
      "y": 810,
      "width": 1300,
      "height": 95,
      "text": "①  Agent A  ───  GET /agents?keyword=weather  ──────────────────────────→  Registry returns webhook URLs + DID\n\n②  Agent A  ───  POST /webhook/sync { AgentMessage }  ──────────────────→  Agent B's Flask server receives + routes to handler\n\n③  If price set:  Agent B returns HTTP 402  →  Agent A auto-pays USDC  →  Retries with X-PAYMENT proof  →  Agent B returns 200",
      "fontSize": 16,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "strokeColor": "#ffffff",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 70,
      "angle": 0,
      "seed": 63,
      "version": 1,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "containerId": null,
      "originalText": "①  Agent A  ───  GET /agents?keyword=weather  ──────────────────────────→  Registry returns webhook URLs + DID\n\n②  Agent A  ───  POST /webhook/sync { AgentMessage }  ──────────────────→  Agent B's Flask server receives + routes to handler\n\n③  If price set:  Agent B returns HTTP 402  →  Agent A auto-pays USDC  →  Retries with X-PAYMENT proof  →  Agent B returns 200",
      "lineHeight": 1.25,
      "groupIds": [],
      "frameId": null,
